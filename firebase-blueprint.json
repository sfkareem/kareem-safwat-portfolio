{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "Unique identifier for the user"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "User's email address"
        },
        "displayName": {
          "type": "string",
          "description": "User's display name"
        },
        "role": {
          "type": "string",
          "enum": ["admin", "user"],
          "description": "User's role in the application"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the user profile was created"
        }
      },
      "required": ["uid", "email", "role"]
    },
    "Contact": {
      "title": "Contact",
      "description": "Contact form submission",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the person"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Email of the person"
        },
        "phone": {
          "type": "string",
          "description": "Phone number of the person"
        },
        "message": {
          "type": "string",
          "description": "Message content"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the message was sent"
        }
      },
      "required": ["name", "email", "message", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles"
    },
    "contacts/{contactId}": {
      "schema": "Contact",
      "description": "Collection of contact form submissions"
    }
  }
}
